# --------------------------------
# 复制此文件内容到 .env 文件中
# 建议保持默认的配置项, 在 .env 文件中可直接忽略
# .env 文件中的配置将被注入环境变量, 并被 app/core/config.py 解析到应用配置中
# --------------------------------

##### 应用配置 ######
# 应用名称, 默认为 FastAPI Template
APP_NAME=<APP-NAME>
# 应用环境: development | testing | production, 默认为 development
APP_ENV=<APP-ENV>
# 调试模式, 默认在开发模式下开启, 建议保持默认
DEBUG=
# 工作进程数, 默认在生产环境多进程，其他环境单进程, 建议保持默认
WORKERS=
# !!!密钥, 必须设置
SECRET_KEY=<SECRET-KEY>

####### 服务配置 ######
# 服务绑定地址, 默认为 0.0.0.0:8080, 建议保持默认
SERVER_HOST=
SERVER_PORT=
# 外部访问地址, 默认为 http://127.0.0.1:8080 (开发环境)
PUBLIC_HOST=<PUBLIC-HOST>
PUBLIC_PORT=<PUBLIC-PORT>
PUBLIC_SCHEME=<PUBLIC-SCHEME>
# API 前缀, 默认为 /api, 建议保持默认
API_PREFIX=

###### !!!管理员信息 ######
SUPERADMIN_NAME=<SUPERADMIN_NAME>
SUPERADMIN_EMAIL=<SUPERADMIN_EMAIL>
SUPERADMIN_PASSWORD=<SUPERADMIN_PASSWORD>

###### 跨域配置 ######
# 前端地址, 默认为 http://localhost:5173 (开发环境)
FRONTEND_URL=<FRONTEND-URL>
# 其他需要跨域配置的外部客户端地址, 默认为空, 建议保持默认
EXTERNAL_URLS=
# 静态文件目录, 默认为项目根目录下的 static 目录 (绝对路径), 建议保持默认
STATIC_DIR=

###### JWT 配置 ######
# JWT 签名算法, 默认为 HS256, 建议保持默认
JWT_ALGORITHM=
# JWT 访问令牌有效期, 默认为 1800 秒(30 分钟), 建议保持默认
ACCESS_TOKEN_EXPIRE_DELTA_SECONDS=
# JWT 刷新令牌有效期, 默认为 604800 秒(7 天), 建议保持默认
REFRESH_TOKEN_EXPIRE_DELTA_SECONDS=

###### 数据库连接信息 ######
## PostgreSQL
# 主机, docker 环境下固定为 db, 本地环境默认为 127.0.0.1
POSTGRES_HOST=<POSTGRES-HOST>
# 端口, 默认为 5432
POSTGRES_PORT=5432
# 数据库名, 默认为 postgres
POSTGRES_DB=<POSTGRES-DB>
# 用户名, 默认为 postgres
POSTGRES_USER=<POSTGRES-USER>
# !!!密码, 必须设置
POSTGRES_PASSWORD=<POSTGRES-PASSWORD>
## Redis
# 主机, docker 环境下默认为 cache, 本地环境为 127.0.0.1
REDIS_HOST=<REDIS-HOST>
# 端口, 默认为 6379
REDIS_PORT=6379
# 数据库, 默认为 0
REDIS_DB=0
# !!!Redis 密码, 必须设置
REDIS_PASSWORD=<REDIS-PASSWORD>
